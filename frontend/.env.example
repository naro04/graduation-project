# API base URL (used by apiClient and api.js).
# لو بدك اللوكل يعرض نفس بيانات الدومين: لا تضبط هالمتغير (أو ضبطه بنفس رابط Railway).
# لو بدك اللوكل يربط على باكند محلي: VITE_API_BASE_URL=http://localhost:5000/api/v1
# VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
